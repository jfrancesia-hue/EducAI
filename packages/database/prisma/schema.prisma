generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String     @id @default(cuid())
  type      TenantType
  name      String
  slug      String     @unique
  country   String     @default("AR")
  metadata  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  creditLedger UsageCreditLedger[]
  family    Family?
  roles     Role[]
  school    School?
  users     User[]

  @@index([type])
  @@index([deletedAt])
}

model User {
  id                                                    String               @id @default(cuid())
  tenantId                                              String?
  email                                                 String               @unique
  fullName                                              String
  role                                                  UserRole
  locale                                                String               @default("es-AR")
  avatarUrl                                             String?
  lastLoginAt                                           DateTime?
  createdAt                                             DateTime             @default(now())
  updatedAt                                             DateTime             @updatedAt
  deletedAt                                             DateTime?
  auditLogs                                             AuditLog[]
  comments                                              CommunityComment[]
  posts                                                 CommunityPost[]
  parent                                                Parent?
  ParentalConsent_ParentalConsent_parentUserIdToUser    ParentalConsent[]    @relation("ParentalConsent_parentUserIdToUser")
  ParentalConsent_ParentalConsent_revokedByUserIdToUser ParentalConsent[]    @relation("ParentalConsent_revokedByUserIdToUser")
  student                                               Student?
  teacher                                               Teacher?
  tenant                                                Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleBindings                                          UserRoleAssignment[]

  @@index([tenantId])
  @@index([role])
  @@index([deletedAt])
}

model Role {
  id          String               @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  tenant      Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  roles       RolePermission[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model School {
  id         String          @id @default(cuid())
  tenantId   String          @unique
  name       String
  country    String          @default("AR")
  province   String?
  city       String?
  taxId      String?
  logoUrl    String?
  settings   Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?
  classrooms Classroom[]
  posts      CommunityPost[]
  curricula  Curriculum[]
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  students   Student[]
  teachers   Teacher[]

  @@index([tenantId])
  @@index([deletedAt])
}

model Family {
  id           String         @id @default(cuid())
  tenantId     String         @unique
  name         String
  country      String         @default("AR")
  billingData  Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  parents      Parent[]
  reports      ParentReport[]
  students     Student[]
  subscription Subscription?

  @@index([tenantId])
  @@index([deletedAt])
}

model Parent {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String    @unique
  familyId  String
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  family    Family    @relation(fields: [familyId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([familyId])
  @@index([deletedAt])
}

model Teacher {
  id          String              @id @default(cuid())
  tenantId    String
  userId      String              @unique
  schoolId    String
  title       String?
  subjects    String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  creditLedger UsageCreditLedger[]
  classrooms  Classroom[]
  lessonPlans LessonPlan[]
  school      School              @relation(fields: [schoolId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  enrollments TeacherEnrollment[]

  @@index([tenantId])
  @@index([schoolId])
  @@index([deletedAt])
}

model Student {
  id              String            @id @default(cuid())
  tenantId        String
  userId          String?           @unique
  familyId        String
  schoolId        String?
  firstName       String
  lastName        String
  birthDate       DateTime?
  grade           Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  enrollments     Enrollment[]
  ParentalConsent ParentalConsent[]
  family          Family            @relation(fields: [familyId], references: [id])
  school          School?           @relation(fields: [schoolId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])
  profile         StudentProfile?

  @@index([tenantId])
  @@index([familyId])
  @@index([schoolId])
  @@index([deletedAt])
}

model Classroom {
  id          String       @id @default(cuid())
  tenantId    String
  schoolId    String
  teacherId   String?
  name        String
  grade       Int
  shift       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  school      School       @relation(fields: [schoolId], references: [id])
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]

  @@index([tenantId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([deletedAt])
}

model Subject {
  id          String       @id @default(cuid())
  tenantId    String?
  name        String
  code        String
  area        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  enrollments Enrollment[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Enrollment {
  id          String    @id @default(cuid())
  tenantId    String
  studentId   String
  classroomId String
  subjectId   String?
  status      String    @default("active")
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])
  subject     Subject?  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, classroomId, subjectId])
  @@index([tenantId])
}

model StudentProfile {
  id                  String                  @id @default(cuid())
  tenantId            String
  studentId           String                  @unique
  grade               Int
  country             String
  curriculum          String
  learningStyle       String?
  strongSubjects      String[]
  weakSubjects        String[]
  diagnosticCompleted Boolean                 @default(false)
  diagnosticScore     Json?
  preferredChannel    String                  @default("whatsapp")
  whatsappPhone       String?                 @unique
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?
  diagnosticState     Json?
  achievements        Achievement[]
  conversations       Conversation[]
  whatsappContacts    EducaiWhatsappContact[]
  sessions            LearningSession[]
  student             Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model EducaiWhatsappContact {
  id               String                    @id @default(cuid())
  tenantId         String
  studentProfileId String
  role             EducaiWhatsappContactRole
  phone            String
  displayName      String?
  canReceiveTutor  Boolean                   @default(true)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @default(now()) @updatedAt
  deletedAt        DateTime?
  studentProfile   StudentProfile            @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, role, phone])
  @@index([tenantId])
  @@index([phone])
  @@index([deletedAt])
}

model Conversation {
  id               String         @id @default(cuid())
  tenantId         String
  studentProfileId String
  subject          String
  topic            String?
  status           String         @default("active")
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  summary          String?
  competencesUsed  String[]
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  messages         Message[]

  @@index([tenantId])
  @@index([studentProfileId])
}

model Message {
  id             String       @id @default(cuid())
  tenantId       String
  conversationId String
  role           String
  content        String
  mediaUrl       String?
  mediaType      String?
  tokensUsed     Int?
  modelUsed      String?
  safetyStatus   String       @default("safe")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@index([createdAt])
}

model LearningSession {
  id                String         @id @default(cuid())
  tenantId          String
  studentProfileId  String
  subject           String
  topic             String
  durationMinutes   Int
  competencesScored Json
  completed         Boolean        @default(false)
  createdAt         DateTime       @default(now())
  studentProfile    StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentProfileId])
}

model Achievement {
  id               String         @id @default(cuid())
  tenantId         String
  studentProfileId String
  type             String
  name             String
  description      String
  earnedAt         DateTime       @default(now())
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentProfileId])
}

model ParentReport {
  id          String    @id @default(cuid())
  tenantId    String
  familyId    String
  periodStart DateTime
  periodEnd   DateTime
  summary     Json
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([familyId])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  familyId           String             @unique
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  provider           String
  providerSubId      String?
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  providerCustomerId String?
  externalReference  String?            @unique
  product            EducaiProduct      @default(APOYOAI)
  planCode           String             @default("free")
  BillingEvent       BillingEvent[]
  family             Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([provider, providerSubId])
}

model Curriculum {
  id        String          @id @default(cuid())
  tenantId  String
  schoolId  String
  name      String
  grade     Int
  subject   String
  version   Int             @default(1)
  content   Json
  source    String
  language  String          @default("es-AR")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gaps      CurriculumGap[]
  plans     LessonPlan[]

  @@index([tenantId])
  @@index([schoolId])
}

model CurriculumGap {
  id                 String     @id @default(cuid())
  tenantId           String
  curriculumId       String
  category           String
  severity           String
  description        String
  recommendation     String
  referenceFramework String
  createdAt          DateTime   @default(now())
  curriculum         Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([curriculumId])
}

model LessonPlan {
  id              String      @id @default(cuid())
  tenantId        String
  teacherId       String
  curriculumId    String?
  grade           Int
  subject         String
  topic           String
  durationMinutes Int
  competences     String[]
  objectives      Json
  activities      Json
  resources       Json
  assessment      Json
  adaptations     Json?
  status          String      @default("draft")
  generatedByAI   Boolean     @default(false)
  rating          Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  curriculum      Curriculum? @relation(fields: [curriculumId], references: [id])
  teacher         Teacher     @relation(fields: [teacherId], references: [id])

  @@index([tenantId])
  @@index([teacherId])
}

model ContentLibraryItem {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  subjectArea String
  grade       Int[]
  content     Json
  mediaUrl    String?
  language    String
  tags        String[]
  generatedAt DateTime @default(now())
  verified    Boolean  @default(false)
  verifiedBy  String?

  @@index([subjectArea])
}

model TeacherCourse {
  id                String              @id @default(cuid())
  title             String
  description       String
  topics            Json
  duration          Int
  level             String
  modules           Json
  accreditedBy      String?
  certificatePoints Int                 @default(0)
  verified          Boolean             @default(false)
  enrollments       TeacherEnrollment[]
}

model TeacherEnrollment {
  id             String        @id @default(cuid())
  tenantId       String
  teacherId      String
  courseId       String
  progress       Float         @default(0)
  completed      Boolean       @default(false)
  certificateUrl String?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  course         TeacherCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher        Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId])
  @@index([tenantId])
}

model CommunityPost {
  id        String             @id @default(cuid())
  tenantId  String?
  authorId  String
  schoolId  String?
  title     String
  content   String
  tags      String[]
  upvotes   Int                @default(0)
  createdAt DateTime           @default(now())
  deletedAt DateTime?
  comments  CommunityComment[]
  author    User               @relation(fields: [authorId], references: [id])
  school    School?            @relation(fields: [schoolId], references: [id])

  @@index([tenantId])
  @@index([schoolId])
}

model CommunityComment {
  id        String        @id @default(cuid())
  tenantId  String?
  postId    String
  authorId  String
  content   String
  createdAt DateTime      @default(now())
  deletedAt DateTime?
  author    User          @relation(fields: [authorId], references: [id])
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([postId])
}

model ContactLead {
  id          String   @id @default(cuid())
  name        String
  email       String
  institution String?
  quantity    Int?
  product     String?
  plan        String?
  message     String?
  source      String   @default("website_contact_form")
  status      String   @default("open")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([createdAt])
}

model BillingEvent {
  id              String        @id
  provider        String
  providerEventId String
  eventType       String
  status          String
  subscriptionId  String?
  tenantId        String?
  payload         Json
  receivedAt      DateTime      @default(now())
  processedAt     DateTime?
  outcome         String?
  errorMessage    String?
  Subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([provider, providerEventId])
  @@index([receivedAt])
  @@index([subscriptionId])
  @@index([tenantId])
}

model UsageCreditLedger {
  id          String        @id @default(cuid())
  tenantId    String
  teacherId   String?
  product     EducaiProduct
  unit        String
  amount      Int
  source      String
  reason      String?
  referenceId String?
  metadata    Json?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher     Teacher?      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([tenantId, product, unit])
  @@index([teacherId])
  @@index([referenceId])
  @@index([expiresAt])
  @@index([createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ParentalConsent {
  id                                         String    @id
  tenantId                                   String
  studentId                                  String
  parentUserId                               String
  documentVersion                            String
  termsAccepted                              Boolean
  privacyAccepted                            Boolean
  aiProcessingAccepted                       Boolean
  signedAt                                   DateTime  @default(now())
  ipAddress                                  String
  userAgent                                  String    @db.VarChar(512)
  revokedAt                                  DateTime?
  revokedByUserId                            String?
  revocationReason                           String?   @db.VarChar(512)
  metadata                                   Json?
  createdAt                                  DateTime  @default(now())
  updatedAt                                  DateTime
  User_ParentalConsent_parentUserIdToUser    User      @relation("ParentalConsent_parentUserIdToUser", fields: [parentUserId], references: [id])
  User_ParentalConsent_revokedByUserIdToUser User?     @relation("ParentalConsent_revokedByUserIdToUser", fields: [revokedByUserId], references: [id])
  Student                                    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, documentVersion, parentUserId])
  @@index([parentUserId])
  @@index([studentId, revokedAt])
  @@index([tenantId])
}

model ProcessedTwilioMessage {
  messageSid  String    @id
  receivedAt  DateTime  @default(now())
  completedAt DateTime?
  outcome     String    @default("received")
  tenantId    String?
  studentId   String?

  @@index([receivedAt])
  @@index([tenantId])
}

enum TenantType {
  SCHOOL
  FAMILY
  MINISTRY
}

enum UserRole {
  SUPER_ADMIN
  MINISTRY
  SCHOOL_ADMIN
  COORDINATOR
  TEACHER
  PARENT
  STUDENT
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  FAMILY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  IN_GRACE_PERIOD
}

enum EducaiProduct {
  EDUCAI
  APOYOAI
}

enum EducaiWhatsappContactRole {
  STUDENT
  PARENT
  GUARDIAN
}
