# Conventional Commits validator (liviano, sin commitlint extra).
commit_msg_file="$1"
commit_msg=$(head -n1 "$commit_msg_file")
pattern='^(feat|fix|chore|docs|refactor|test|perf|style|build|ci|revert)(\([a-z0-9/.-]+\))?!?: .{1,}'

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
  echo ""
  echo "❌ Commit message no sigue Conventional Commits."
  echo ""
  echo "Ejemplos válidos:"
  echo "  feat(api): agregar endpoint POST /students"
  echo "  fix(whatsapp-agent): validar firma Twilio en webhook"
  echo "  chore: actualizar turbo.json"
  echo "  docs(architecture): ADR-003 integracion Twilio"
  echo ""
  exit 1
fi
