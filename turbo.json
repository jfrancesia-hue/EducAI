{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.example"],
  "globalEnv": ["DATABASE_URL", "DATABASE_URL_APP", "SKIP_RLS_SMOKE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
