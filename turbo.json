{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.example"],
  "globalEnv": ["ANTHROPIC_API_KEY", "DATABASE_URL", "NODE_ENV", "OPENAI_API_KEY", "REDIS_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
