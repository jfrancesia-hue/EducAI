# App
NODE_ENV=development
PORT=4000
PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# Database / Supabase
DATABASE_URL=postgresql://educai:educai_dev_password@localhost:5432/educai?schema=educai
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_PUBLIC_WEBHOOK_URL=http://localhost:4000/webhooks/twilio
TWILIO_FORCE_PROTOCOL=http
TWILIO_SKIP_SIGNATURE_VALIDATION=true
TWILIO_DRY_RUN=true

# Crisis alerts (tutor safety)
# Numero de WhatsApp del equipo de crisis al que se avisa cuando el tutor detecta
# una senal de crisis (autolesion, suicidio, abuso, violencia). NUNCA es la familia.
# Override por colegio: tenant.metadata.crisisAlertWhatsappTo.
CRISIS_ALERT_WHATSAPP_TO=whatsapp:+5493810000000
# (Recomendado) SID de la plantilla de WhatsApp aprobada (Content API de Twilio,
# formato HX...) para la alerta de crisis. Permite que el aviso salga aunque la
# ventana de 24 hs este cerrada (mensaje iniciado por el negocio); sin plantilla,
# el texto libre solo se entrega dentro de esa ventana. Variables de la plantilla:
# {{1}} alumno, {{2}} severidad, {{3}} link al panel. Vacio = se usa texto libre.
CRISIS_ALERT_TEMPLATE_SID=

# Payments
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_WEBHOOK_URL=http://localhost:4000/webhooks/mercadopago
# Ventana anti-replay de la firma del webhook (ms). Vacio = default 5 min. 0 = desactiva.
MERCADOPAGO_SIGNATURE_TOLERANCE_MS=

# Auth
# Audiencias JWT permitidas (coma-separadas). Ademas se acepta "authenticated"
# (default de los access tokens de Supabase).
SUPABASE_JWT_AUDIENCE=

# Rate limit del tutor IA por web (requests/minuto por usuario). Default 20.
WEB_TUTOR_RATE_LIMIT_PER_MIN=20

# Swagger en produccion: si ENABLE_SWAGGER_DOCS=true, /docs exige basic-auth "usuario:clave".
# Sin esta variable, /docs NO se expone en produccion.
ENABLE_SWAGGER_DOCS=
SWAGGER_BASIC_AUTH=

# Onboarding: activar suscripciones pagas sin pago real. PROHIBIDO en produccion.
APOYOAI_AUTO_ACTIVATE_PAID_SIGNUPS=false

# Infra
SENTRY_DSN=
POSTHOG_KEY=

