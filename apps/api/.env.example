# App
NODE_ENV=development
PORT=4000
PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# Database / Supabase
DATABASE_URL=postgresql://educai:educai_dev_password@localhost:5432/educai?schema=educai
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_PUBLIC_WEBHOOK_URL=http://localhost:4000/webhooks/twilio
TWILIO_FORCE_PROTOCOL=http
TWILIO_SKIP_SIGNATURE_VALIDATION=true
TWILIO_DRY_RUN=true

# Crisis alerts (tutor safety)
# Numero de WhatsApp del equipo de crisis al que se avisa cuando el tutor detecta
# una senal de crisis (autolesion, suicidio, abuso, violencia). NUNCA es la familia.
# Override por colegio: tenant.metadata.crisisAlertWhatsappTo.
CRISIS_ALERT_WHATSAPP_TO=whatsapp:+5493810000000

# Payments
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_WEBHOOK_URL=http://localhost:4000/webhooks/mercadopago

# Infra
SENTRY_DSN=
POSTHOG_KEY=

