# URL server-side de la API NestJS para proxear /api/agent/run.
# La Web ya no llama Anthropic directo: todo el trafico al modelo
# pasa por la API para que aplique auth, audit, rate-limit y billing.
EDUCAI_API_URL=http://localhost:4000

# Login fundador local (piloto). Si falta cualquiera, /api/auth/local-login
# devuelve 404 deshabilitado.
EDUCAI_FOUNDER_EMAIL=
EDUCAI_FOUNDER_PASSWORD=

# Secreto compartido con la API para HS256 (mientras se completa la migracion
# a Supabase Auth con custom claims hook — ver docs/architecture/ADR-003).
EDUCAI_SESSION_JWT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DOCENTE=
STRIPE_PRICE_EQUIPO=
STRIPE_PRICE_ESCUELA=
STRIPE_PRICE_RED=
STRIPE_PRICE_MINISTERIO=
